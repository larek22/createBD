QWidget {
    background-color: #10131a;
    color: #f5f5f7;
}
QPushButton {
    background-color: #2f3b52;
    border: 1px solid #46546b;
    border-radius: 6px;
    padding: 6px 12px;
}
QPushButton:hover {
    background-color: #3d4b68;
}
QLineEdit, QPlainTextEdit, QTextEdit, QComboBox {
    background-color: #1b202c;
    border: 1px solid #3a4254;
    border-radius: 6px;
    padding: 4px 6px;
}
